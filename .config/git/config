[core]
    editor = nvim
    excludesfile = "~/.config/git/ignore"

[commit]
    gpgsign = true

[merge]
    conflictstyle = diff3

[color]
    status = true
    branch = true
    interactive = true
    diff = true
    ui = true

[advice]
    addEmptyPathspec = false
    addIgnoredFile = false

[init]
    defaultBranch = "main"

[alias]
    stagels = diff --name-only --cached

